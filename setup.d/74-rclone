#!/bin/bash
# vim: set et fenc=utf-8 ff=unix sts=4 sw=4 ts=8 :
common_lib="$(dirname "$(readlink -f "$0")")/common-lib"
if [[ -f "$common_lib" ]]; then
    # shellcheck source=common-lib
    . "$common_lib"
else
    echo "[FAIL] Cannot find common-lib."
    exit 1
fi

# Early Skip Flows
# rclone version check is done inline; no full early skip needed

# Install / update rclone via official install script
version=$(rclone --version 2>/dev/null | head -n 1 || echo "")
current_version=$(curl -fsS https://downloads.rclone.org/version.txt)

if [[ -n "$version" ]] && [[ "$version" == "$current_version" ]]; then
    pass "rclone is already the latest version"
else
    change "Install / update rclone"
    curl https://rclone.org/install.sh | sudo bash
fi

# Set user_allow_other in /etc/fuse.conf
if grep -q '^user_allow_other' /etc/fuse.conf; then
    pass "user_allow_other is already set in /etc/fuse.conf"
else
    change 'add "user_allow_other" to /etc/fuse.conf'
    echo "user_allow_other" | sudo tee -a /etc/fuse.conf
fi

# Remove old vfs/refresh cron job if it exists
if crontab -l 2>/dev/null | grep -q 'vfs/refresh'; then
    change "Remove old rclone vfs/refresh cron job"
    crontab -l 2>/dev/null | grep -v 'vfs/refresh' | crontab - || true
else
    pass "No stale vfs/refresh cron job found"
fi

# Reload systemd user daemon (service file deployed via dotfiles symlink)
systemctl --user daemon-reload

# Auto-detect drive remotes and enable mounts
mapfile -t drive_remotes < <(rclone listremotes --long 2>/dev/null | awk '$2 == "drive" { sub(/:$/, "", $1); print $1 }')

if [[ ${#drive_remotes[@]} -eq 0 ]]; then
    warn "No rclone drive remotes found. Run 'rclone config' to set up remotes, then:"
    warn "  systemctl --user enable --now rclone@<remote-name>"
else
    for remote in "${drive_remotes[@]}"; do
        local_mount="/mnt/$remote"
        if [[ ! -d "$local_mount" ]]; then
            change "Create mount point $local_mount"
            sudo mkdir -p "$local_mount"
            sudo chown "$USER":"$(id -gn)" "$local_mount"
        elif [[ ! -O "$local_mount" ]]; then
            change "Fix ownership of $local_mount"
            sudo chown "$USER":"$(id -gn)" "$local_mount"
        fi
        if systemctl --user is-enabled "rclone@$remote" &>/dev/null; then
            pass "rclone@$remote already enabled"
        else
            change "Enable and start rclone@$remote"
            systemctl --user enable --now "rclone@$remote"
        fi
    done
fi
