#!/bin/bash
# vim: set et fenc=utf-8 ff=unix sts=4 sw=4 ts=8 :
common_lib="$(dirname "$(readlink -f "$0")")/common-lib"
if [[ -f "$common_lib" ]]; then
    # shellcheck source=common-lib
    . "$common_lib"
else
    echo "[FAIL] Cannot find common-lib."
    exit 1
fi

# Early Skip Flows
# Ensure uv is in PATH
export PATH="$HOME/.local/bin:$PATH"

if command -v powerline >/dev/null 2>&1 \
    && [[ -f "$HOME/.local/share/fonts/PowerlineSymbols.otf" ]] \
    && [[ -f "$HOME/.config/fontconfig/conf.d/10-powerline-symbols.conf" ]]; then
    pass "powerline and font targets are already installed"
    exit 0
fi

if ! command -v uv &>/dev/null; then
    fail "uv not found. prerequisite setup.d/53-python-apps should prepare it first."
    exit 1
fi

repair_powerline_uv_tool() {
    local tool_dir="$HOME/.local/share/uv/tools/powerline-status"
    local tool_bin="$tool_dir/bin"
    local pyvenv_cfg="$tool_dir/pyvenv.cfg"
    local python_home=""
    local version_info=""
    local version_mm=""
    local python_target=""
    local launcher=""

    if [[ ! -d "$tool_bin" ]]; then
        return
    fi

    if [[ -f "$pyvenv_cfg" ]]; then
        python_home="$(sed -n 's/^home = //p' "$pyvenv_cfg" | head -n1)"
        version_info="$(sed -n 's/^version_info = //p' "$pyvenv_cfg" | head -n1)"
    fi

    if [[ -n "$version_info" ]]; then
        version_mm="$(cut -d. -f1,2 <<<"$version_info")"
    fi

    if [[ -n "$python_home" ]]; then
        if [[ -n "$version_mm" && -x "$python_home/python$version_mm" ]]; then
            python_target="$python_home/python$version_mm"
        elif [[ -x "$python_home/python3" ]]; then
            python_target="$python_home/python3"
        fi
    fi

    if [[ -n "$python_target" && ! -e "$tool_bin/python" ]]; then
        change "Repair $tool_bin/python"
        ln -sfn "$python_target" "$tool_bin/python"
    fi

    mkdir -p "$HOME/.local/bin"
    for launcher in powerline powerline-config powerline-daemon powerline-lint powerline-render; do
        if [[ -f "$tool_bin/$launcher" && ! -e "$HOME/.local/bin/$launcher" ]]; then
            change "Link ~/.local/bin/$launcher -> $tool_bin/$launcher"
            ln -sfn "$tool_bin/$launcher" "$HOME/.local/bin/$launcher"
        fi
    done
}

repair_powerline_uv_tool
ensure_user_owned_dir "$HOME/.cache/uv"
uv tool install --with powerline-gitstatus powerline-status -p 3.8
repair_powerline_uv_tool

# Setup  https://github.com/powerline/fonts
mkdir -p ~/.local/share/fonts/
(
    cd ~/.local/share/fonts/ || exit
    if [[ -f PowerlineSymbols.otf ]]; then
        ts_flag=(-z PowerlineSymbols.otf)
    fi
    curl -fL "${ts_flag[@]}" -o PowerlineSymbols.otf https://github.com/powerline/powerline/raw/develop/font/PowerlineSymbols.otf
)
mkdir -p ~/.config/fontconfig/conf.d/
(
    cd ~/.config/fontconfig/conf.d/ || exit
    if [[ -f 10-powerline-symbols.conf ]]; then
        ts_flag=(-z 10-powerline-symbols.conf)
    fi
    curl -fL "${ts_flag[@]}" -o 10-powerline-symbols.conf https://github.com/powerline/powerline/raw/develop/font/10-powerline-symbols.conf
)

# patch fonts for powerline
fc-cache -vf ~/.local/share/fonts/ ~/.fonts
