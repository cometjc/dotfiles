#!/bin/bash
# shellcheck shell=bash
# vim: set et fenc=utf-8 ff=unix sts=4 sw=4 ts=8 :

function errexit() {
    local err=$?
    set +o xtrace
    local code="${1:-1}"
    fail "Error in ${BASH_SOURCE[1]}:${BASH_LINENO[0]}. '${BASH_COMMAND}' exited with status $err"
    # Print out the stack trace described by $function_stack
    if [ ${#FUNCNAME[@]} -gt 2 ]; then
        info "Call tree:"
        for ((i = 1; i < ${#FUNCNAME[@]} - 1; i++)); do
            info " $i: ${BASH_SOURCE[$i + 1]}:${BASH_LINENO[$i]} ${FUNCNAME[$i]}(...)"
        done
    fi
    info "Exiting with status ${code}"
    exit "${code}"
}
# trap ERR to provide an error handler whenever a command exits nonzero
#  this is a more verbose version of set -o errexit
trap 'errexit' ERR
# setting errtrace allows our ERR trap handler to be propagated to functions,
#  expansions and subshells
set -eE -o pipefail -o errtrace

# import common functions
# Get the directory where this script is located
_common_lib_dir="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
. "$_common_lib_dir/../files/.bashrc.d/02-functions"

# 定義顏色 — 用 TERM 判斷，不依賴 fd 1 是否為 tty（setup_script_output_prefix 會將 fd 1 導入 pipe）
if [[ "${TERM:-dumb}" != dumb ]] && command -v tput >/dev/null 2>&1; then
    GREEN=$(tput setaf 2 2>/dev/null || echo "")
    YELLOW=$(tput setaf 3 2>/dev/null || echo "")
    RED=$(tput setaf 1 2>/dev/null || echo "")
    CYAN=$(tput setaf 6 2>/dev/null || echo "")
    NC=$(tput sgr0 2>/dev/null || echo "")
else
    GREEN=""
    YELLOW=""
    RED=""
    CYAN=""
    NC=""
fi

# Max visible width of [$script-name] across all setup.d scripts.
# Update if a script with a longer name than [80-desktop-configs] (20 chars) is added.
_SETUP_SCRIPT_NAME_MAX=20

# Outer setup script needs padding so its log levels align with subscript output.
# Subscript lines add (_SETUP_SCRIPT_NAME_MAX + 1) visible chars via inner sed;
# the outer script's own lines must prepend the same number of spaces.
if [[ -z "${SETUP_STATUS_DIR:-}" ]]; then
    _LOG_PAD=$(printf "%$((_SETUP_SCRIPT_NAME_MAX + 1))s" '')
else
    _LOG_PAD=""
fi

pass() {
    echo -e "${_LOG_PAD}${GREEN}[PASS]${NC} $1"
}

info() {
    echo -e "${_LOG_PAD}${CYAN}[INFO]${NC} $1"
}

change() {
    echo -e "${_LOG_PAD}${YELLOW}[CHANGE]${NC} $1"
}

fail() {
    echo -e "${_LOG_PAD}${RED}[FAIL]${NC} $1"
}

warn() {
    export setup_warned=1
    echo -e "${_LOG_PAD}${YELLOW}[WARN]${NC} $1"
}

# Only source /etc/lsb-release on Linux systems that have it
if [[ -f /etc/lsb-release ]]; then
    # shellcheck source=/dev/null
    source /etc/lsb-release
    if [[ $DISTRIB_ID = LinuxMint ]] && [[ -f /etc/upstream-release/lsb-release ]]; then
        # for Linux Mint, we treat it as Ubuntu
        # shellcheck source=/dev/null
        source /etc/upstream-release/lsb-release
    fi
fi

# Ensure platform is set (used by multiple setup scripts)
# shellcheck disable=SC2034
if [[ -z "${platform:-}" ]]; then
    case $(uname) in
        Linux)
            platform='linux'
            ;;
        FreeBSD)
            platform='freebsd'
            ;;
        Darwin)
            platform='mac'
            ;;
        *)
            platform='unknown'
            ;;
    esac
fi

case $platform in
    'linux')
        check_pkg() { [[ "$(dpkg-query --show --showformat='${db:Status-Status}' "$1" 2>/dev/null)" = installed ]]; }
        update_pkg_list() { sudo env "PATH=$PATH" apt update; }
        # apt-update-smart: smart apt update that only runs when repo configs change
        apt-update-smart() {
            local apt_update_script
            apt_update_script="$HOME/.bin/apt-update-smart"
            # Fallback to files/.bin if ~/.bin doesn't exist
            if [[ ! -f "$apt_update_script" ]]; then
                apt_update_script="$_common_lib_dir/../files/.bin/apt-update-smart"
            fi
            if [[ -f "$apt_update_script" ]]; then
                bash "$apt_update_script" update
            else
                # Fallback to regular update if script not found
                update_pkg_list
            fi
        }
        # aptitude can solve depenency problem for clang-*, setup aptitude first
        if ! check_pkg aptitude; then
            sudo apt-get install -q -y aptitude
        fi
        ensure_pkg() {
            info "Checking installation of: $*"
            #shellcheck disable=SC2034
            mapfile -t installed_pkgs < <(dpkg-query --show --showformat='${db:Status-Status} ${Package}\n' "$@" | grep ^installed | cut -d" " -f2)
            pkgs_to_install=()
            for pkg in "$@"; do
                if ! array_contains installed_pkgs "$pkg"; then
                    pkgs_to_install+=("$pkg")
                fi
            done

            if [[ ${#pkgs_to_install[@]} -eq 0 ]]; then
                pass "All packages are already installed"
                return 0
            fi

            change "Installing missing packages: ${pkgs_to_install[*]}"
            if ! sudo apt-get install -y "${pkgs_to_install[@]}"; then
                fail "Failed to install packages: ${pkgs_to_install[*]}"
                return 1
            fi
            pass "Successfully installed all packages"
        }
        ;;
    'mac')
        check_pkg() { brew list -1 | grep -q "^${1}\$"; }
        update_pkg_list() { :; }
        ensure_pkg() { brew install "$@"; }
        if ! brew help >/dev/null; then
            ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"
        fi
        ;;
esac

setup_script_output_prefix() {
    caller=${BASH_SOURCE[2]##*/}
    local pad=""
    if [[ -n "${SETUP_STATUS_DIR:-}" ]]; then
        local pad_len=$((_SETUP_SCRIPT_NAME_MAX - ${#caller} - 2))
        ((pad_len > 0)) && pad=$(printf '%*s' "$pad_len" '')
    fi
    exec 5>&1
    exec 1> >(sed -E "s#^#${YELLOW}[$caller]${NC}${pad} #" >&5)
    exec 6>&2
    exec 2> >(sed -E "s#^#${YELLOW}[$caller]${NC}${pad} #" >&6)
}

record_setup_status() {
    local status="$1"
    local caller
    caller=${BASH_SOURCE[2]##*/}
    if [[ -n "${SETUP_STATUS_DIR:-}" && -n "$caller" ]]; then
        printf '%s\n' "$status" >"$SETUP_STATUS_DIR/$caller"
    fi
}

skip_script_if_executed() {
    if [[ " $* " = *" -f "* ]]; then
        info "Force setup enabled, executing..."
        return
    fi
    caller=${BASH_SOURCE[2]##*/}
    executed_ts=$(getfattr -n user.executed -d "${caller}" 2>/dev/null | sed -n 's/.*="\(.*\)"/\1/p' || echo "")
    if [[ -z "${executed_ts}" ]]; then
        info "Executing..."
        return
    fi
    commonlib_ts=$(stat -c %Y "${BASH_SOURCE[1]}")
    if ((executed_ts < commonlib_ts)); then
        info "Common library updated, executing..."
        return
    fi
    file_ts=$(stat -c %Y "${caller}")
    if ((executed_ts > file_ts)); then
        pass "Script already executed, skipping"
        record_setup_status skip
        export skipped=1
        exit
    fi
    info "Executing..."
}

mark_script_executed() {
    caller=${BASH_SOURCE[2]##*/}
    caller_path="${BASH_SOURCE[2]}"
    # Get absolute path if relative
    if [[ ! "$caller_path" = /* ]]; then
        caller_path="$(cd "$(dirname "$caller_path")" && pwd)/$(basename "$caller_path")" 2>/dev/null || return 0
    fi
    if [[ -f "$caller_path" ]]; then
        # Try to get timestamp, but don't fail on I/O errors
        timestamp=$(date +%s 2>/dev/null) || return 0
        setfattr -n user.executed -v "$timestamp" "$caller_path" 2>/dev/null || true
    fi
}

cleanup() {
    local exit_status=$?
    if ((exit_status == 0)) && [[ -z "${skipped}" ]]; then
        mark_script_executed
        if [[ -n "${setup_warned:-}" ]]; then
            record_setup_status warn
        else
            record_setup_status executed
        fi
    elif ((exit_status != 0)) && [[ -z "${skipped}" ]]; then
        record_setup_status fail
    fi
}

ensure_user_owned_dir() {
    local dir="$1"
    if [[ -e "$dir" ]] && [[ ! -O "$dir" ]]; then
        change "Fix ownership of $dir"
        sudo chown -R "$USER":"$(id -gn)" "$dir"
    fi
    mkdir -p "$dir"
}

ensure_mise_cache_writable() {
    local cache_dir="${1:-$HOME/.cache/mise}"
    ensure_user_owned_dir "$cache_dir"
}

# shellcheck disable=SC2154
trap 'status=$?; cleanup; exit $status' EXIT
setup_script_output_prefix
skip_script_if_executed "$@"
