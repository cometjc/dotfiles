#!/bin/bash
# vim: set et fenc=utf-8 ff=unix sts=4 sw=4 ts=8 :
common_lib="$(dirname "$(readlink -f "$0")")/common-lib"
if [[ -f "$common_lib" ]]; then
    # shellcheck source=common-lib
    . "$common_lib"
else
    echo "[FAIL] Cannot find common-lib."
    exit 1
fi

# Early Skip Flows
export PATH="$HOME/.local/bin:$PATH"
if ! command -v mise &>/dev/null; then
    fail "mise not found. prerequisite setup.d/50-mise should prepare it first."
    exit 1
fi

if command -v node &>/dev/null \
    && command -v bun &>/dev/null \
    && command -v codex &>/dev/null \
    && command -v copilot &>/dev/null \
    && command -v gemini &>/dev/null; then
    pass "node, bun, codex, copilot, and gemini are already available, skipping node apps installation"
    exit 0
fi

ensure_user_owned_dir "$HOME/.cache/mise"
mise self-update --yes

for app in node bun; do
    mise use -g "$app@latest" || {
        fail "Failed to set $app to latest version"
        exit 1
    }
done

for app in @openai/codex @github/copilot @google/gemini-cli; do
    bun install -g "$app" || {
        fail "Failed to set $app to latest version"
        exit 1
    }
done
