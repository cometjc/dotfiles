#!/bin/bash
# vim: set et fenc=utf-8 ff=unix sts=4 sw=4 ts=8 :
common_lib="$(dirname "$(readlink -f "$0")")/common-lib"
if [[ -f "$common_lib" ]]; then
    # shellcheck source=common-lib
    . "$common_lib"
else
    echo "[FAIL] Cannot find common-lib."
    exit 1
fi

# Early Skip Flows
# brew packages are always updated on each run via `brew install` (idempotent)
# No full early skip; rely on xattr-based skip from common-lib
brew_bin="${BREW_BIN:-/home/linuxbrew/.linuxbrew/bin/brew}"
command -v brew >/dev/null 2>&1 || NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
eval "$("$brew_bin" shellenv)"

packages=(
    gcc
    derailed/k9s/k9s
    fx
    kubectx
)

for pkg in "${packages[@]}"; do
    brew install "$pkg"
done
