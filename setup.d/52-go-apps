#!/bin/bash
# vim: set et fenc=utf-8 ff=unix sts=4 sw=4 ts=8 :
common_lib="$(dirname "$(readlink -f "$0")")/common-lib"
if [[ -f "$common_lib" ]]; then
    # shellcheck source=common-lib
    . "$common_lib"
else
    echo "[FAIL] Cannot find common-lib."
    exit 1
fi

# Early Skip Flows
if ! command -v mise &>/dev/null && [[ ! -x "$HOME/.local/bin/mise" ]]; then
    pass "mise not found, skipping go apps installation"
    exit 0
fi

ensure_user_owned_dir "$HOME/.cache/mise"
eval "$("$HOME/.local/bin/mise" activate bash)"
mise use --global go@latest
eval "$("$HOME/.local/bin/mise" activate bash)"

packages=(
    'github.com/BurntSushi/toml/cmd/tomlv'
    'github.com/golangci/golangci-lint/cmd/golangci-lint'
    'golang.org/x/tools/cmd/goimports'
    'mvdan.cc/sh/v3/cmd/shfmt'
    'github.com/nao1215/gup'
    'github.com/mikefarah/yq/v4'
    'github.com/google/yamlfmt/cmd/yamlfmt'
    # pup@latest(目前解析到 0.4.0) 在 mise go backend 會觸發 -mod=readonly 失敗，先固定可用版本
    'github.com/ericchiang/pup@v0.3.9'
)

for pkg in "${packages[@]}"; do
    versioned_pkg="$pkg"
    [[ "$pkg" == *@* ]] || versioned_pkg="$pkg@latest"
    mise use -g "go:$versioned_pkg"
done
mise use -g fzf@latest

gup update || true
