#!/bin/bash
# vim: set et fenc=utf-8 ff=unix sts=4 sw=4 ts=8 :
common_lib="$(dirname "$(readlink -f "$0")")/common-lib"
if [[ -f "$common_lib" ]]; then
    # shellcheck source=common-lib
    . "$common_lib"
else
    echo "[FAIL] Cannot find common-lib."
    exit 1
fi

# Early Skip Flows
export PATH="$HOME/.local/bin:$PATH"
mise_bin="$(command -v mise 2>/dev/null || true)"
if [[ -z "$mise_bin" && -x "$HOME/.local/bin/mise" ]]; then
    mise_bin="$HOME/.local/bin/mise"
fi
if [[ -z "$mise_bin" ]]; then
    fail "Cannot find mise executable. prerequisite setup.d/50-mise should prepare it first."
    exit 1
fi

required_tools=(
    tomlv
    golangci-lint
    goimports
    shfmt
    gup
    yq
    yamlfmt
    pup
    fzf
)

all_tools_available=true
for tool in "${required_tools[@]}"; do
    if ! command -v "$tool" &>/dev/null; then
        all_tools_available=false
        break
    fi
done

if $all_tools_available; then
    pass "Go app targets and fzf are already available, skipping installation"
    exit 0
fi

ensure_user_owned_dir "$HOME/.cache/mise"
eval "$("$mise_bin" activate bash)"
"$mise_bin" use --global go@latest
eval "$("$mise_bin" activate bash)"

packages=(
    'github.com/BurntSushi/toml/cmd/tomlv'
    'github.com/golangci/golangci-lint/cmd/golangci-lint'
    'golang.org/x/tools/cmd/goimports'
    'mvdan.cc/sh/v3/cmd/shfmt'
    'github.com/nao1215/gup'
    'github.com/mikefarah/yq/v4'
    'github.com/google/yamlfmt/cmd/yamlfmt'
    # pup@latest(目前解析到 0.4.0) 在 mise go backend 會觸發 -mod=readonly 失敗，先固定可用版本
    'github.com/ericchiang/pup@v0.3.9'
)

for pkg in "${packages[@]}"; do
    versioned_pkg="$pkg"
    [[ "$pkg" == *@* ]] || versioned_pkg="$pkg@latest"
    "$mise_bin" use -g "go:$versioned_pkg"
done
"$mise_bin" use -g fzf@latest

gup update || true
