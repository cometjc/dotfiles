{
  "version": 1,
  "hooks": {
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "$HOME/repo/tmux-agent-status/scripts/workmux-hook-start.sh"
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "$HOME/repo/tmux-agent-status/scripts/workmux-hook-done.sh"
      }
    ]
  }
}
