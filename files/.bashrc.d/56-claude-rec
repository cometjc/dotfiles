#!/bin/bash

claude() {
    local cast_dir="/tmp/cast"
    mkdir -p "$cast_dir"
    local pane_id
    pane_id=$(tmux display-message -p '#S:#I.#P' 2>/dev/null || echo "notmux")
    local cast_file="$cast_dir/claude-${pane_id}-$(date +%Y%m%d-%H%M).cast"
    if ! command -v asciinema >/dev/null 2>&1; then
        command claude --dangerously-skip-permissions "$@"
        echo "claude-rec: warning: asciinema not installed, session was not recorded" >&2
        return
    fi
    asciinema rec --overwrite -c "bash --norc -i -c 'command claude --dangerously-skip-permissions $*'" "$cast_file"
    # Keep only the latest 10 recordings
    ls -t "$cast_dir"/claude-*.cast 2>/dev/null | tail -n +11 | xargs -r rm -f
}
