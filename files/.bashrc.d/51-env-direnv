#!/bin/bash
_shared_envrc_sync_on_chpwd() {
    local sync_script="${SHARED_ENVRC_SYNC_SCRIPT:-$HOME/shared_codes/shared-envrc-sync}"
    if [[ -x "$sync_script" ]]; then
        SHARED_ENVRC_SYNC_QUIET_NOOP=1 "$sync_script" sync-on-enter >/dev/null 2>&1 || true
    fi
}

if declare -p chpwd_functions >/dev/null 2>&1 && ! array_contains chpwd_functions _shared_envrc_sync_on_chpwd; then
    chpwd_functions+=(_shared_envrc_sync_on_chpwd)
fi

if command -v direnv >/dev/null 2>&1; then
    _bashrc_cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/bashrc"
    _direnv_hook_cache="${_bashrc_cache_dir}/direnv-hook.bash"
    _direnv_bin="$(command -v direnv)"
    if [[ ! -s "$_direnv_hook_cache" || "$_direnv_bin" -nt "$_direnv_hook_cache" ]]; then
        mkdir -p "$_bashrc_cache_dir"
        direnv hook bash >"$_direnv_hook_cache"
    fi
    # shellcheck source=/dev/null
    source "$_direnv_hook_cache"
fi

if [[ -e "$PWD/.envrc" || -e "$PWD/.envrc.shared" || -e "$PWD/.envrc.local" ]]; then
    _shared_envrc_sync_on_chpwd
fi
